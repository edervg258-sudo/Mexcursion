const { getDefaultConfig } = require('expo/metro-config');
const path = require('path');

const config = getDefaultConfig(__dirname);

const MOCK = path.resolve(__dirname, 'expo-sqlite-mock.js');

config.resolver.resolveRequest = (context, moduleName, platform) => {
  if (platform === 'web') {
    // Bloquear cualquier import que venga desde expo-sqlite en web
    if (
      context.originModulePath?.includes('expo-sqlite') ||
      moduleName === 'expo-sqlite' ||
      moduleName.includes('expo-sqlite')
    ) {
      return { filePath: MOCK, type: 'sourceFile' };
    }
  }
  return context.resolveRequest(context, moduleName, platform);
};

module.exports = config;